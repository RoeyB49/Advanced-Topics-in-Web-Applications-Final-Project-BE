# Backend production environment
NODE_ENV=production
PORT=4000

# MongoDB (remote service on your server)
# Example format:
# mongodb://admin:<PASSWORD>@127.0.0.1:21771/animon?authSource=admin
MONGO_URI=

# JWT secrets
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Optional social auth
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# AI settings
AI_EXTERNAL_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
AI_MIN_INTERVAL_MS=1500
AI_CACHE_TTL_MS=300000
AI_CHAT_MIN_INTERVAL_MS=1500
AI_CHAT_CACHE_TTL_MS=300000
